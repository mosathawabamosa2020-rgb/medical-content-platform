{
  "name": "medical-content-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node tools/clean_next_lock.js && next build --webpack",
    "typecheck": "tsc --noEmit",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "test": "jest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:push": "dotenv -e ./.env.local -- prisma db push",
    "manual:migrate": "node scripts/run_migrations.js",
    "db:apply": "node scripts/run_migrations.js",
    "metrics": "node tools/show_project_metrics.js",
    "seed": "ts-node prisma/seed.ts",
    "bench:retrieval": "node tools/benchmark_retrieval.js",
    "ops:backup": "node tools/ops_backup.js",
    "ops:restore": "node tools/ops_restore.js",
    "ops:readiness": "node tools/ops_readiness_snapshot.js",
    "ops:preflight": "node tools/ops_preflight.js",
    "ops:export-validation": "node tools/export_validation_outputs.js",
    "ops:live-proof": "node tools/run_live_discovery_proof.js",
    "ops:retrieval-visibility-proof": "node tools/run_retrieval_visibility_proof.js",
    "ops:vector-proof": "node tools/run_vector_retrieval_proof.js"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ],
    "prisma/schema.prisma": [
      "npx prisma format"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.426.0",
    "@next-auth/prisma-adapter": "^1.0.5",
    "@prisma/client": "5.22.0",
    "@xenova/transformers": "^2.17.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.70.4",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.0.0",
    "formidable": "^2.1.2",
    "ioredis": "^5.3.2",
    "next": "^16.1.6",
    "next-auth": "^4.22.1",
    "openai": "^4.9.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.10.0",
    "pino": "^8.0.0",
    "pino-pretty": "^10.0.0",
    "playwright": "^1.41.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "swr": "^2.4.1",
    "tesseract.js": "^7.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "autoprefixer": "^10.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "husky": "^9.1.7",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "lint-staged": "^15.5.2",
    "node-mocks-http": "^1.11.0",
    "postcss": "^8.4.0",
    "prettier": "^3.6.2",
    "prisma": "5.22.0",
    "tailwindcss": "^3.4.0",
    "tailwindcss-rtl": "^0.9.0",
    "ts-node": "^10.9.2",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  }
}
