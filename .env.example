# APPLICATION
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-long-random-secret

# DATABASE
DATABASE_URL=postgresql://platform_user:platform_pass@localhost:5432/medical_platform

# REDIS
REDIS_URL=redis://localhost:6379

# MINIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin
MINIO_BUCKET_REFERENCES=references
MINIO_BUCKET_PROCESSED=processed
MINIO_BUCKET_IMAGES=images
MINIO_REGION=us-east-1

# AI PHASE 1
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_GENERATION_MODEL=gpt-4o-mini

# AI PHASE 2 (commented)
# EMBEDDING_SERVICE_URL=http://localhost:8000
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_DIMENSIONS=1024

# EXTERNAL SOURCES
PUBMED_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils
PUBMED_API_KEY=
SEMANTIC_SCHOLAR_KEY=
OPENALEX_EMAIL=
PUBMED_RPS=3
FDA_RPS=2
WIKIMEDIA_RPS=2
OPEN_MEDICAL_LIBRARIES_RPS=2
OPENALEX_RPS=2

# SECURITY
CSRF_SECRET=replace-with-long-random-secret
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

# MONITORING (commented)
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3001
